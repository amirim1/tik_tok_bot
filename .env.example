# Telegram Bot Token (обязательно)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Файл логов
LOG_FILE=bot.log

# Директория для временных видеофайлов
TEMP_DIR=temp_videos

# Максимальный размер видео в MB
MAX_FILE_SIZE_MB=50

# Лимит запросов от одного пользователя
RATE_LIMIT_CALLS=5
RATE_LIMIT_WINDOW=60  # секунд

# Файл для хранения данных rate limit (persistence между перезапусками)
RATE_LIMIT_FILE=rate_limit.json

# Ограничение доступа по ID пользователей (через запятую).
# Оставьте пустым, чтобы разрешить всем.
ALLOWED_USERS=

# Таймаут загрузки видео (сек)
DOWNLOAD_TIMEOUT=30

# Количество повторов при ошибке API
MAX_DOWNLOAD_RETRIES=2
